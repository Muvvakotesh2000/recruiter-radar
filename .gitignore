# =============================================================
# RecruiterRadar — .gitignore
# =============================================================

# -------------------------
# Dependencies
# -------------------------
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# -------------------------
# Next.js build output
# -------------------------
/.next/
/out/
/build/
.next

# -------------------------
# Environment variables — NEVER commit these
# They contain API keys, secrets, and credentials
# -------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# -------------------------
# Supabase local dev
# -------------------------
/supabase/.branches/
/supabase/.temp/

# -------------------------
# OS generated files
# -------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -------------------------
# Editor / IDE
# -------------------------
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.workspace
*.sublime-project
*.sublime-workspace
.history/

# -------------------------
# Logs
# -------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo
next-env.d.ts

# -------------------------
# Testing & coverage
# -------------------------
/coverage/
/.nyc_output/
/test-results/
/playwright-report/

# -------------------------
# Vercel
# -------------------------
.vercel

# -------------------------
# Misc
# -------------------------
*.pem
*.p12
*.key
*.cert
.cache/
.parcel-cache/
dist/
tmp/
temp/
